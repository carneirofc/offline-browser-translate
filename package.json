{
  "name": "local-llm-translate-extension",
  "version": "1.7.0",
  "private": true,
  "description": "Privacy-focused browser extension that translates web pages using local LLMs (Ollama, LM Studio, llama.cpp).",
  "homepage": "https://github.com/carneirofc/offline-browser-translate",
  "license": "MIT",
  "author": "Cláudio Carneiro",
  "repository": {
    "type": "git",
    "url": "https://github.com/carneirofc/offline-browser-translate.git"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:ext": "web-ext lint --source-dir=.",
    "build": "web-ext build"
  },
  "webExt": {
    "sourceDir": ".",
    "artifactsDir": "web-ext-artifacts",
    "ignoreFiles": [
      ".github",
      ".github/**",
      ".claude",
      ".claude/**",
      ".agents",
      ".agents/**",
      ".vscode/**",
      "graphify-out",
      "graphify-out/**",
      "node_modules",
      "node_modules/**",
      "skills-lock.json",
      "amo-metadata.json",
      "test",
      "test/**",
      "eslint.config.mjs",
      "vitest.config.js",
      "tsconfig.json",
      "types.js",
      "globals.d.ts",
      "coverage",
      "coverage/**",
      "package.json",
      "package-lock.json",
      "README.md",
      "CHANGELOG.md",
      "LICENSE",
      "assets",
      "assets/**",
      "**/*.zip",
      "**/*.xpi"
    ],
    "build": {
      "overwriteDest": true
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^26.1.1",
    "eslint": "^9.18.0",
    "eslint-plugin-jsdoc": "^63.1.0",
    "globals": "^15.14.0",
    "jsdom": "^29.1.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10",
    "web-ext": "^8.3.0"
  }
}
