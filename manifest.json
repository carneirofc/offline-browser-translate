{
  "manifest_version": 3,
  "name": "Local LLM Translator",
  "short_name": "Translator",
  "version": "1.8.0",
  "description": "Translate web pages with a local LLM (Ollama, LM Studio, llama.cpp). 100% private — your text never leaves your device.",
  "author": "Cláudio Carneiro",
  "developer": {
    "name": "Cláudio Carneiro",
    "url": "https://github.com/carneirofc"
  },
  "homepage_url": "https://github.com/carneirofc/offline-browser-translate",
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "contextMenus"
  ],
  "host_permissions": [
    "http://localhost/*"
  ],
  "optional_host_permissions": ["<all_urls>"],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "web_accessible_resources": [{
    "resources": ["icons/icon48.png"],
    "matches": ["<all_urls>"]
  }],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "scripts": [
      "languages.js",
      "cache.js",
      "defaults.js",
      "background.js"
    ],
    "service_worker": "background.js"
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "local-llm-translator@privacy.extension",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ],
        "optional": []
      }
    }
  }
}
